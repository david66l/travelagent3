# ── Database ──
DATABASE_URL=postgresql+asyncpg://travelagent:travelagent123@postgres:5432/travel_agent

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── LLM (Required) ──
# OpenAI-compatible API endpoint
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Alternative: DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ── Search (Tavily: https://tavily.com, free 1000 calls/month) ──
TAVILY_API_KEY=tvly-your-key-here
SEARCH_ENGINE=tavily

# ── App Settings ──
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ── Crawler ──
CRAWL_RATE_LIMIT=1.0
CRAWL_MAX_RETRIES=3
CRAWL_TIMEOUT=30

# ── Seed Data ──
SEED_DATA_DIR=backend/seed_data
SEED_CITIES=北京,上海,广州,深圳,成都,杭州,西安,重庆,苏州,南京,厦门,青岛,大理,丽江,三亚,长沙,武汉,昆明,桂林,拉萨
